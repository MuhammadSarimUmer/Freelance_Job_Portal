generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum ContractStatus {
  DRAFT
  SIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  DECLINED
  WITHDRAWN
}

enum ProposalSource {
  DEVELOPER_PROPOSAL
  CLIENT_INVITE
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum MilestoneScope {
  INDIVIDUAL
  SHARED
}

enum PaymentStatus {
  PENDING
  DEPOSITED
  RELEASED
  REFUNDED
}

enum PayoutStatus {
  PENDING
  RELEASED
  REFUNDED
}

enum BugSeverity {
  LOW
  MINOR
  MAJOR
  CRITICAL
}

enum BugStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
}

model User {
  userID           String        @id @default(uuid())
  fullName         String
  email            String        @unique
  passwordHash     String
  phoneNumber      String?
  profileImageUrl  String?
  registrationDate DateTime      @default(now())
  accountStatus    AccountStatus @default(ACTIVE)
  emailVerified    Boolean       @default(false)
  emailVerifiedAt  DateTime?
  emailVerificationToken        String?
  emailVerificationTokenExpires DateTime?
  passwordResetOtps PasswordResetOtp[]
  messagesSent     Message[]
  notifications    Notification[]
  disputesRaised   Dispute[]
  reviewsGiven     Review[]      @relation("ReviewsGiven")
  reviewsReceived  Review[]      @relation("ReviewsReceived")
  developer        Developer?
  client           Client?
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

