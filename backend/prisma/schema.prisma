generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum AvailabilityStatus {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum ProficiencyLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum ContractStatus {
  DRAFT
  SIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  IN_REVIEW
  COMPLETED
}

enum PaymentStatus {
  PENDING
  DEPOSITED
  RELEASED
  REFUNDED
}

enum BugSeverity {
  LOW
  MINOR
  MAJOR
  CRITICAL
}

enum BugStatus {
  REPORTED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  userID           String        @id @default(uuid())
  fullName         String
  email            String        @unique
  passwordHash     String
  phoneNumber      String?
  registrationDate DateTime      @default(now())
  accountStatus    AccountStatus @default(ACTIVE)
  developer        Developer?
  client           Client?
}

