model Developer {
  developerID        String                @id @default(uuid())
  userID             String                @unique
  experienceYears    Int                   @default(0)
  hourlyRate         Decimal               @db.Decimal(10, 2)
  portfolioURL       String?
  cvUrl              String?
  availabilityStatus AvailabilityStatus    @default(AVAILABLE)
  user               User                  @relation(fields: [userID], references: [userID], onDelete: Cascade)
  knownTechs         DeveloperTechnology[]
  assignedProjects   ContractAssignment[]
  proposals          ContractProposal[]
  milestoneAssignments MilestoneAssignment[]
  payouts            PaymentPayout[]
}

model Client {
  clientID       String            @id @default(uuid())
  userID         String            @unique
  companyName    String?
  billingAddress String?
  country        String
  user           User              @relation(fields: [userID], references: [userID], onDelete: Cascade)
  contracts      ProjectContract[]
}

model TechnologyStack {
  techID     String                @id @default(uuid())
  techName   String                @unique
  category   String
  version    String?
  developers DeveloperTechnology[]
  contracts  ContractTechnology[]
}

model DeveloperTechnology {
  developerID      String
  techID           String
  proficiencyLevel ProficiencyLevel
  yearsExperience  Int              @default(0)
  developer        Developer        @relation(fields: [developerID], references: [developerID], onDelete: Cascade)
  tech             TechnologyStack  @relation(fields: [techID], references: [techID], onDelete: Cascade)

  @@id([developerID, techID])
}

model Application {
  appID          String            @id @default(uuid())
  appName        String
  appType        String
  description    String?           @db.Text
  createdDate    DateTime          @default(now())
  currentVersion String            @default("1.0.0")
  contracts      ProjectContract[]
}

model ProjectContract {
  contractID   String               @id @default(uuid())
  clientID     String
  appID        String
  title        String
  description  String               @db.Text
  startDate    DateTime
  endDate      DateTime?
  totalAmount  Decimal              @db.Decimal(12, 2)
  status       ContractStatus       @default(DRAFT)
  signedDate   DateTime?
  client       Client               @relation(fields: [clientID], references: [clientID], onDelete: Restrict)
  application  Application          @relation(fields: [appID], references: [appID], onDelete: Restrict)
  assignments  ContractAssignment[]
  proposals    ContractProposal[]
  technologies ContractTechnology[]
  milestones   Milestone[]
  bugReports   BugReport[]
  messages     Message[]
  reviews      Review[]
  disputes     Dispute[]
}

model ContractProposal {
  proposalID     String          @id @default(uuid())
  contractID     String
  developerID    String
  source         ProposalSource
  status         ProposalStatus  @default(PENDING)
  message        String?         @db.Text
  proposedRate   Decimal?        @db.Decimal(10, 2)
  role           String?
  declineReason  String?         @db.Text
  createdAt      DateTime        @default(now())
  decidedAt      DateTime?
  developer      Developer       @relation(fields: [developerID], references: [developerID], onDelete: Cascade)
  contract       ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)

  @@unique([contractID, developerID])
}

model ContractAssignment {
  assignmentID           String          @id @default(uuid())
  developerID            String
  contractID             String
  role                   String
  assignedDate           DateTime        @default(now())
  contributionPercentage Decimal         @db.Decimal(5, 2)
  paymentShare           Decimal         @db.Decimal(5, 2)
  leaveRequestedAt       DateTime?
  leaveRequestedBy       String?
  developer              Developer       @relation(fields: [developerID], references: [developerID], onDelete: Restrict)
  contract               ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)

  @@unique([developerID, contractID])
}

model ContractTechnology {
  contractID    String
  techID        String
  purpose       String?
  requiredLevel ProficiencyLevel
  contract      ProjectContract  @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
  tech          TechnologyStack  @relation(fields: [techID], references: [techID], onDelete: Restrict)

  @@id([contractID, techID])
}

model Milestone {
  milestoneID     String          @id @default(uuid())
  contractID      String
  title           String
  description     String          @db.Text
  dueDate         DateTime
  completeDate    DateTime?
  milestoneAmount Decimal         @db.Decimal(10, 2)
  status          MilestoneStatus @default(PENDING)
  scope           MilestoneScope  @default(INDIVIDUAL)
  contract        ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
  assignments     MilestoneAssignment[]
  escrow          PaymentEscrow?
}

model MilestoneAssignment {
  milestoneID String
  developerID String
  milestone   Milestone @relation(fields: [milestoneID], references: [milestoneID], onDelete: Cascade)
  developer   Developer @relation(fields: [developerID], references: [developerID], onDelete: Restrict)

  @@id([milestoneID, developerID])
}

model PaymentEscrow {
  escrowID             String        @id @default(uuid())
  milestoneID          String        @unique
  depositAmount        Decimal       @db.Decimal(10, 2)
  depositDate          DateTime      @default(now())
  releaseDate          DateTime?
  paymentStatus        PaymentStatus @default(PENDING)
  transactionReference String?       @unique
  milestone            Milestone     @relation(fields: [milestoneID], references: [milestoneID], onDelete: Restrict)
  payouts              PaymentPayout[]
}

model PaymentPayout {
  payoutID     String       @id @default(uuid())
  escrowID     String
  developerID  String
  amount       Decimal      @db.Decimal(12, 2)
  sharePercent Decimal      @db.Decimal(5, 2)
  status       PayoutStatus @default(RELEASED)
  releaseDate  DateTime?
  createdAt    DateTime     @default(now())
  escrow       PaymentEscrow @relation(fields: [escrowID], references: [escrowID], onDelete: Cascade)
  developer    Developer     @relation(fields: [developerID], references: [developerID], onDelete: Restrict)

  @@index([developerID])
  @@index([escrowID])
}

model BugReport {
  bugID        String          @id @default(uuid())
  contractID   String
  title        String
  description  String          @db.Text
  severity     BugSeverity
  status       BugStatus       @default(REPORTED)
  createdDate  DateTime        @default(now())
  resolvedDate DateTime?
  contract     ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
}

model Message {
  messageID  String   @id @default(uuid())
  contractID String
  senderID   String
  content    String   @db.Text
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)

  contract   ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
  sender     User            @relation(fields: [senderID], references: [userID], onDelete: Cascade)

  @@index([contractID])
  @@index([senderID])
}

model Review {
  reviewID   String   @id @default(uuid())
  contractID String
  reviewerID String
  revieweeID String
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  contract  ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
  reviewer  User            @relation("ReviewsGiven", fields: [reviewerID], references: [userID], onDelete: Cascade)
  reviewee  User            @relation("ReviewsReceived", fields: [revieweeID], references: [userID], onDelete: Cascade)

  @@index([revieweeID])
  @@unique([contractID, reviewerID, revieweeID])
}

model Dispute {
  disputeID  String        @id @default(uuid())
  contractID String
  raisedByID String
  reason     String        @db.Text
  status     DisputeStatus @default(OPEN)
  resolution String?       @db.Text
  createdAt  DateTime      @default(now())
  resolvedAt DateTime?

  contract  ProjectContract @relation(fields: [contractID], references: [contractID], onDelete: Cascade)
  raisedBy  User            @relation(fields: [raisedByID], references: [userID], onDelete: Cascade)

  @@index([contractID])
  @@index([raisedByID])
}

model Notification {
  notificationID String   @id @default(uuid())
  userID         String
  type           String
  title          String
  body           String
  isRead         Boolean  @default(false)
  link           String?
  createdAt      DateTime @default(now())

  user User @relation(fields: [userID], references: [userID], onDelete: Cascade)

  @@index([userID, isRead])
}

model PasswordResetOtp {
  otpID     String   @id @default(uuid())
  userID    String
  otpHash   String
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userID], references: [userID], onDelete: Cascade)

  @@index([userID])
}
